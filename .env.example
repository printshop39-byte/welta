# Welta Chikankari — environment template.
# Copy this file to .env.local and fill in values. Never commit .env.local.

# Oracle APEX / ORDS REST base URL — server-only.
# When BOTH this and APEX_API_TOKEN are unset, the app falls back to
# mock data in src/lib/mock/*. See src/lib/apex.ts.
APEX_ORDS_BASE_URL=

# APEX bearer token — server-only. Do NOT prefix with NEXT_PUBLIC_.
APEX_API_TOKEN=

# Public site URL — used for SEO (canonical, OG, sitemap).
NEXT_PUBLIC_SITE_URL=https://weltachikankari.in

# WhatsApp atelier number used by the cart "Order on WhatsApp" CTA.
# Country code first, no plus sign, no spaces. e.g. 919876543210
# Hardcoded fallback in source is the live Welta number 918468900336;
# only set this env var if you want to point a staging build at a
# different test number.
NEXT_PUBLIC_WHATSAPP_NUMBER=918468900336
