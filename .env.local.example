# Copy this file to .env.local and fill in the values.
# When APEX_ORDS_BASE_URL and APEX_API_TOKEN are both set, the app reads
# real data from ORDS. Otherwise it falls back to mock data
# (see src/lib/mock/* and src/lib/apex.ts -> USE_MOCK).

APEX_ORDS_BASE_URL=
APEX_API_TOKEN=
NEXT_PUBLIC_SITE_URL=https://weltachikankari.in
